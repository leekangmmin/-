#!/bin/zsh
set -e

APP_BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$APP_BIN_DIR/../../.." && pwd)"
APP_DIR="$PROJECT_DIR/NativeMacApp"
APP_BIN="$APP_DIR/.build/release/ToeflNativeApp"
SERVER_BIN="$APP_BIN_DIR/toefl_server"


# 1. FastAPI 서버 백그라운드 실행 (포트 8000)
if [ -x "$SERVER_BIN" ]; then
  "$SERVER_BIN" &
  SERVER_PID=$!
  sleep 2
else
  # 바이너리가 없으면 시스템 python3로 직접 실행 (venv 필요 없음)
  PYTHON_BIN="$(command -v python3 || command -v python)"
  if [ -x "$PYTHON_BIN" ]; then
    "$PYTHON_BIN" "$PROJECT_DIR/app/main.py" &
    SERVER_PID=$!
    sleep 2
  else
    osascript -e 'display dialog "FastAPI 서버 실행 파일/파이썬이 없습니다.\nPython3가 필요합니다." buttons {"확인"} default button "확인"'
    exit 1
  fi
fi

# 2. SwiftUI 클라이언트 실행
"$APP_BIN"

# 3. SwiftUI 앱 종료 시 서버도 종료
kill $SERVER_PID
