#!/bin/zsh
set -e

APP_BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$APP_BIN_DIR/../../.." && pwd)"
APP_DIR="$PROJECT_DIR/NativeMacApp"
APP_BIN="$APP_DIR/.build/release/ToeflNativeApp"
SERVER_BIN="$APP_BIN_DIR/toefl_server"

# 1. FastAPI 서버 백그라운드 실행 (포트 8000)
if [ -x "$SERVER_BIN" ]; then
  "$SERVER_BIN" &
  SERVER_PID=$!
  sleep 2
else
  osascript -e 'display dialog "FastAPI 서버 실행 파일이 없습니다.\nbuild_standalone_server.command를 먼저 실행해 주세요." buttons {"확인"} default button "확인"'
  exit 1
fi

# 2. SwiftUI 클라이언트 실행
"$APP_BIN"

# 3. SwiftUI 앱 종료 시 서버도 종료
kill $SERVER_PID
